node_modules/
.env
.DS_Store
dist/
dashboard/dist/
# The web/ landing page IS tracked (open source). Its node_modules/ and dist/ are
# already covered by the global ignores above; it's kept OUT of the npm package via
# the package.json "files" allowlist, not via gitignore.
*.tgz
tmp/
dashboard-loaded.png
dashboard-*.png
# Browser-MCP / dev screenshots dropped at the project root.
/*.png
.playwright-mcp/
**/.playwright-mcp/
replied_issues.txt
.scratch/
# Legacy state dir (pre-rename) — never track in the pikiloom repo.
# Canonical state dir: ignore runtime state, keep committed project skills.
# Never commit Python bytecode caches, even under skills/ — MUST stay after the
# skills un-ignore above (gitignore is last-match-wins) or it gets re-included.
**/__pycache__/
*.pyc
.pikiclaw/*
!.pikiclaw/skills/
!.pikiclaw/skills/**
.pikiloom/*
!.pikiloom/skills/
!.pikiloom/skills/**
